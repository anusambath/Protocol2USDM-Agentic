# Google Cloud Vertex AI (recommended for Gemini models with clinical content)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Alternative: Google AI Studio (may block medical content due to safety filters)
# GOOGLE_API_KEY=AIzaSy...

# Anthropic (for Claude models)
# CLAUDE_API_KEY=sk-ant-...

# OpenAI (for GPT models)
# OPENAI_API_KEY=sk-proj-...

# CDISC API (optional, for CORE conformance validation)
# CDISC_API_KEY=...
