{
  "dashboard": {
    "id": null,
    "uid": "p2u-overview",
    "title": "Protocol2USDM — Overview",
    "tags": ["p2u"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Uptime",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [{ "expr": "p2u_uptime_seconds", "legendFormat": "Uptime" }],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "id": 2,
        "title": "Total Extractions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [{ "expr": "sum(p2u_agent_executions_total)", "legendFormat": "Total" }]
      },
      {
        "id": 3,
        "title": "Failure Rate (5m)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [{ "expr": "sum(rate(p2u_agent_failures_total[5m])) / sum(rate(p2u_agent_executions_total[5m]))", "legendFormat": "Failure Rate" }],
        "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.05, "color": "yellow" }, { "value": 0.1, "color": "red" }] } } }
      },
      {
        "id": 4,
        "title": "Entity Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [{ "expr": "sum(p2u_context_store_entities)", "legendFormat": "Entities" }]
      },
      {
        "id": 5,
        "title": "Agent Execution Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [{ "expr": "p2u_agent_duration_seconds", "legendFormat": "{{ agent_id }}" }],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "id": 6,
        "title": "Agent Confidence Scores",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [{ "expr": "p2u_agent_confidence_score", "legendFormat": "{{ agent_id }}" }],
        "fieldConfig": { "defaults": { "min": 0, "max": 1 } }
      },
      {
        "id": 7,
        "title": "Extraction Pipeline Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [{ "expr": "p2u_extraction_duration_seconds", "legendFormat": "{{ protocol_id }}" }],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "id": 8,
        "title": "Message Queue Depth",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [{ "expr": "p2u_message_queue_depth", "legendFormat": "Queue Depth" }]
      },
      {
        "id": 9,
        "title": "Enrichment Coverage",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
        "targets": [{ "expr": "p2u_enrichment_coverage_ratio", "legendFormat": "Coverage" }],
        "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 0.7, "color": "yellow" }, { "value": 0.85, "color": "green" }] } } }
      },
      {
        "id": 10,
        "title": "USDM Validation Failures",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 20 },
        "targets": [{ "expr": "sum(p2u_usdm_validation_failures_total)", "legendFormat": "Failures" }],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } }
      }
    ]
  }
}
